{
  "name": "@orbital-stellar/abi-registry",
  "version": "0.1.0",
  "description": "Canonical Soroban ABI client, schema helpers, and registry publisher interface for Orbital.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "schema",
    "specs/well-known",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "abi-registry-generate": "./bin/abi-registry-generate"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/determined-001/orbital_stellar.git",
    "directory": "packages/abi-registry"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "validate": "node validate.js",
    "seed:well-known": "tsx scripts/seed-well-known.ts"
  },
  "dependencies": {
    "@stellar/js-xdr": "4.0.0",
    "@stellar/stellar-sdk": "^16.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "ajv": "^8.17.1",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  }
}
